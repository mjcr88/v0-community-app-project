{
    "name": "rio-agent",
    "version": "0.1.0",
    "description": "Río AI Community Assistant — Mastra agent service (Sprint 0 scaffold)",
    "type": "module",
    "scripts": {
        "dev": "mastra dev -d src",
        "build": "mastra build -s -d src",
        "start": "MASTRA_STUDIO_PATH=.mastra/output/studio node .mastra/output/index.mjs",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "@mastra/core": "^1.13.2",
        "@mastra/hono": "^1.2.4",
        "@mastra/memory": "^1.8.2",
        "@mastra/pg": "^1.8.0",
        "zod": "3.25.76"
    },
    "overrides": {
        "zod": "3.25.76"
    },
    "devDependencies": {
        "@types/node": "^22",
        "eslint": "^9",
        "mastra": "^1.3.12",
        "tsx": "^4",
        "typescript": "^5"
    },
    "engines": {
        "node": ">=20"
    }
}